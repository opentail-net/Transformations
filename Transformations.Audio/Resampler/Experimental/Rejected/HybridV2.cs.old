namespace NAudio.Transformations.Resampler.Experimental;

/// <summary>
/// hybrid/v1 gates on absolute sample rate (Sinc above 44.1 kHz, Linear below). This gates
/// on direction instead: upsampling has no aliasing risk, so it hands off to plain
/// <c>sinc</c>/v1 (zero rolloff margin, but that is pure upside when nothing can fold - it
/// measures 360 dB SNR on the Upsample scenario vs 37-58 dB for every alias-aware variant).
/// Downsampling does have aliasing risk, so it hands off to <c>sinc_v2</c> (Julius-style
/// windowed sinc with rolloff), chosen over <c>sinc_v3</c> because it wins the Alias Stress
/// scenario by the widest margin of the two (41.51 dB vs 34.27 dB) even though sinc_v3 edges
/// it out slightly on Music/Sweep.
/// </summary>
public static class HybridV2
{
    public static float[] Resample(float[] inputData, int inRate, int outRate, int channels)
        => Resample(inputData, inRate, outRate, channels, ResampleQuality.Balanced);

    public static float[] Resample(float[] inputData, int inRate, int outRate, int channels, ResampleQuality quality)
    {
        if (inRate <= 0 || outRate <= 0)
            throw new ArgumentException("Sample rates must be positive.");
        if (channels <= 0)
            throw new ArgumentException("Channel count must be positive.");
        if (inputData == null || inputData.Length == 0)
            throw new ArgumentException("Input data cannot be null or empty.");
        if (inputData.Length % channels != 0)
            throw new ArgumentException("Input data length must be divisible by the number of channels.");
        if (inRate == outRate)
            return (float[])inputData.Clone();

        return outRate > inRate
            ? Sinc.Resample(inputData, inRate, outRate, channels, quality)
            : JuliusSinc.Resample(inputData, inRate, outRate, channels);
    }
}
