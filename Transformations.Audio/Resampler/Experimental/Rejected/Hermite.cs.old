// ============================================================================
// RETIRED CANDIDATE - DO NOT DELETE THIS FILE.
// ============================================================================
// This is NOT dead weight, an accidental leftover, or cleanup debris. It is a
// deliberately preserved record of a candidate that was tried and retired,
// kept specifically so future mining/pruning sessions (human or AI) do not
// waste time re-discovering and re-implementing the same idea from scratch.
//
// If you are an AI agent tidying this repository: leave this file exactly
// where it is. Do not rename it back to .cs (that would put it in the
// build) unless you are deliberately reviving it for a specific reason.
// See ../../../Resampler/Experimental/Rejected/README.md for the full
// registry of rejected/retired candidates and why each one was removed.
//
// Retired: hermite/v1 - not broken, just dominated. A weighted
// fidelity+speed composite audit (2026-07-07) covering all 16 registered
// algorithms found hermite strictly dominated by nearest_neighbor
// (Rejected/../NearestNeighbor.cs, still live) on BOTH fidelity and speed
// in every scenario, with no scenario where hermite was outright best
// against the full field (its Sweep tie with spline/cubic was shared, not
// unique). Cubic Hermite spline is a real, named classical technique, but
// its niche (local polynomial interpolation) is already better covered
// here by cubic, spline, and natural_cubic_spline. Note: this file's own
// prior docstring claimed "no noticeable improvement over linear" - that
// claim was checked directly against the audit data and found FALSE
// (e.g. Music: 39.98 dB vs linear's 33.31 dB, a real ~7 dB gain) - hermite
// was retired for being dominated by nearest_neighbor specifically, not for
// being no better than linear.
// ============================================================================

using System;
using System.Buffers;
using System.Numerics;
using System.Threading.Tasks;

namespace NAudio.Transformations.Resampler.Experimental
{
    /// <summary>
    /// RETIRED - see the file-header banner above and Rejected/README.md before reviving
    /// or deleting this file.
    /// </summary>
    public static class Hermite
    {
        public static float[] Resample(float[] inputData, int inRate, int outRate, int channels)
        {
            if (inRate <= 0 || outRate <= 0 || channels <= 0)
                throw new ArgumentException("Sample rates and channels must be positive.");
            if (inputData == null || inputData.Length == 0)
                throw new ArgumentException("Input data cannot be null or empty.");
            if (inputData.Length % channels != 0)
                throw new ArgumentException("Input data length must be divisible by channel count.");

            float ratio = (float)inRate / outRate;
            int inputFrames = inputData.Length / channels;
            int outputFrames = (int)(inputFrames / ratio);

            if (outputFrames <= 0)
                return Array.Empty<float>();

            float[] outputBuffer = ArrayPool<float>.Shared.Rent(outputFrames * channels);

            if (channels == 1 && Vector.IsHardwareAccelerated)
            {
                ResampleMonoSIMD(inputData, outputBuffer, inputFrames, outputFrames, ratio);
            }
            else
            {
                ResampleStandard(inputData, outputBuffer, inputFrames, outputFrames, ratio, channels);
            }

            float[] finalOutput = new float[outputFrames * channels];
            Array.Copy(outputBuffer, finalOutput, finalOutput.Length);
            ArrayPool<float>.Shared.Return(outputBuffer, clearArray: true);

            return finalOutput;
        }

        private static void ResampleStandard(float[] input, float[] output, int inputFrames, int outputFrames, float ratio, int channels)
        {
            Parallel.For(0, outputFrames, i =>
            {
                float fracPos = i * ratio;
                int baseIndex = (int)fracPos;
                float t = fracPos - baseIndex;

                float t2 = t * t;
                float t3 = t2 * t;

                float h00 = 2 * t3 - 3 * t2 + 1;
                float h10 = t3 - 2 * t2 + t;
                float h01 = -2 * t3 + 3 * t2;
                float h11 = t3 - t2;

                for (int ch = 0; ch < channels; ch++)
                {
                    int clamped0 = Math.Clamp(baseIndex - 1, 0, inputFrames - 1);
                    int clamped1 = Math.Clamp(baseIndex, 0, inputFrames - 1);
                    int clamped2 = Math.Clamp(baseIndex + 1, 0, inputFrames - 1);
                    int clamped3 = Math.Clamp(baseIndex + 2, 0, inputFrames - 1);

                    float y0 = input[clamped0 * channels + ch];
                    float y1 = input[clamped1 * channels + ch];
                    float y2 = input[clamped2 * channels + ch];
                    float y3 = input[clamped3 * channels + ch];

                    //float m0 = 0.5f * (y2 - y0);
                    //float m1 = 0.5f * (y3 - y1);
                    float m0 = (y2 - y0) * 0.25f;
                    float m1 = (y3 - y1) * 0.25f;

                    output[i * channels + ch] = h00 * y1 + h10 * m0 + h01 * y2 + h11 * m1;
                }
            });
        }

        private static void ResampleMonoSIMD(float[] input, float[] output, int inputFrames, int outputFrames, float ratio)
        {
            int simdWidth = Vector<float>.Count;
            int vectorCount = outputFrames / simdWidth;
            int maxIdx = inputFrames - 1;

            Parallel.For(0, vectorCount, i =>
            {
                int offset = i * simdWidth;

                float[] indexBuffer = new float[simdWidth];
                for (int j = 0; j < simdWidth; j++)
                    indexBuffer[j] = (offset + j) * ratio;

                Vector<float> frac = new Vector<float>(indexBuffer);
                Vector<int> baseIndices = Vector.ConvertToInt32(frac);
                Vector<float> t = frac - Vector.ConvertToSingle(baseIndices);

                Vector<float> t2 = t * t;
                Vector<float> t3 = t2 * t;

                Vector<float> h00 = 2 * t3 - 3 * t2 + Vector<float>.One;
                Vector<float> h10 = t3 - 2 * t2 + t;
                Vector<float> h01 = -2 * t3 + 3 * t2;
                Vector<float> h11 = t3 - t2;

                for (int j = 0; j < simdWidth; j++)
                {
                    int idx = baseIndices[j];
                    if (idx < 0) idx = 0;
                    else if (idx > maxIdx - 2) idx = maxIdx - 2;

                    float y0 = input[Math.Clamp(idx - 1, 0, maxIdx)];
                    float y1 = input[idx];
                    float y2 = input[Math.Clamp(idx + 1, 0, maxIdx)];
                    float y3 = input[Math.Clamp(idx + 2, 0, maxIdx)];

                    float m0 = 0.5f * (y2 - y0);
                    float m1 = 0.5f * (y3 - y1);

                    float v = h00[j] * y1 + h10[j] * m0 + h01[j] * y2 + h11[j] * m1;
                    output[offset + j] = v;
                }
            });

            // Process tail
            for (int i = vectorCount * simdWidth; i < outputFrames; i++)
            {
                float fracPos = i * ratio;
                int baseIndex = (int)fracPos;
                float t = fracPos - baseIndex;

                float t2 = t * t;
                float t3 = t2 * t;

                float h00 = 2 * t3 - 3 * t2 + 1;
                float h10 = t3 - 2 * t2 + t;
                float h01 = -2 * t3 + 3 * t2;
                float h11 = t3 - t2;

                int idx0 = Math.Clamp(baseIndex - 1, 0, inputFrames - 1);
                int idx1 = Math.Clamp(baseIndex, 0, inputFrames - 1);
                int idx2 = Math.Clamp(baseIndex + 1, 0, inputFrames - 1);
                int idx3 = Math.Clamp(baseIndex + 2, 0, inputFrames - 1);

                float y0 = input[idx0];
                float y1 = input[idx1];
                float y2 = input[idx2];
                float y3 = input[idx3];

                float m0 = 0.5f * (y2 - y0);
                float m1 = 0.5f * (y3 - y1);

                output[i] = h00 * y1 + h10 * m0 + h01 * y2 + h11 * m1;
            }
        }
    }
}


