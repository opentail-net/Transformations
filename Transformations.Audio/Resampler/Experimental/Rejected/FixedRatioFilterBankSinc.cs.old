using System.Collections.Concurrent;

namespace NAudio.Transformations.Resampler.Experimental;

/// <summary>
/// audio-resampler-style fixed-ratio sinc filter bank mined as a separate A/B candidate.
/// </summary>
/// <remarks>
/// This tests the filter-bank/fixed-ratio idea from audio-resampler without taking a native
/// dependency. It builds one Blackman-Harris-windowed low-pass sinc per exact output phase.
/// </remarks>
public static class FixedRatioFilterBankSinc
{
    private const int NumTaps = 128;
    private const int MaxFilters = 1024;

    private static readonly ConcurrentDictionary<KernelKey, double[][]> KernelCache = new();

    public static float[] Resample(float[] inputData, int inRate, int outRate, int channels)
    {
        if (inRate <= 0 || outRate <= 0)
            throw new ArgumentException("Sample rates must be positive.");
        if (channels <= 0)
            throw new ArgumentException("Channel count must be positive.");
        if (inputData is null || inputData.Length == 0)
            throw new ArgumentException("Input data cannot be null or empty.");
        if (inputData.Length % channels != 0)
            throw new ArgumentException("Input data length must be divisible by the number of channels.");
        if (inRate == outRate)
            return (float[])inputData.Clone();

        int inputFrames = inputData.Length / channels;
        int outputFrames = (int)Math.Round(inputFrames * (double)outRate / inRate);
        var output = new float[outputFrames * channels];

        int gcd = GreatestCommonDivisor(inRate, outRate);
        int oldRate = inRate / gcd;
        int newRate = outRate / gcd;
        int filterCount = Math.Min(newRate, MaxFilters);
        bool exactPhases = newRate <= MaxFilters;
        double cutoff = CalculateCutoff(inRate, outRate);
        var kernels = KernelCache.GetOrAdd(
            new KernelKey(oldRate, newRate, filterCount, Quantize(cutoff)),
            _ => BuildKernels(filterCount, cutoff));

        Parallel.For(0, outputFrames, outputFrame =>
        {
            double sourcePosition = outputFrame * oldRate / (double)newRate;
            int center = (int)Math.Floor(sourcePosition);
            double frac = sourcePosition - center;
            double phasePosition = frac * filterCount;
            int phase = (int)Math.Floor(phasePosition);
            double phaseFrac = phasePosition - phase;

            if (phase >= filterCount)
            {
                phase = 0;
                phaseFrac = 0;
                center++;
            }

            int nextPhase = phase + 1;
            if (nextPhase == filterCount)
                nextPhase = 0;

            double[] kernel = kernels[phase];
            double[] nextKernel = kernels[nextPhase];

            for (int channel = 0; channel < channels; channel++)
            {
                double sum = 0;
                double weightSum = 0;

                for (int tap = 0; tap < NumTaps; tap++)
                {
                    int inputFrame = Clamp(center + tap - NumTaps / 2 + 1, 0, inputFrames - 1);
                    double weight = exactPhases
                        ? kernel[tap]
                        : kernel[tap] + (nextKernel[tap] - kernel[tap]) * phaseFrac;
                    sum += inputData[inputFrame * channels + channel] * weight;
                    weightSum += weight;
                }

                output[outputFrame * channels + channel] = weightSum == 0 ? 0 : (float)(sum / weightSum);
            }
        });

        return output;
    }

    private static double[][] BuildKernels(int filterCount, double cutoff)
    {
        var kernels = new double[filterCount][];

        Parallel.For(0, filterCount, phase =>
        {
            double frac = phase / (double)filterCount;
            var kernel = new double[NumTaps];

            for (int tap = 0; tap < NumTaps; tap++)
            {
                int offset = tap - NumTaps / 2 + 1;
                double distance = frac - offset;
                kernel[tap] = cutoff * Sinc(cutoff * distance) * BlackmanHarris(tap, NumTaps);
            }

            kernels[phase] = kernel;
        });

        return kernels;
    }

    private static double CalculateCutoff(int inRate, int outRate)
    {
        if (outRate >= inRate)
            return 1.0;

        double resampleRatio = outRate / (double)inRate;
        double lowpassRatio = 1.0 - 7.5 / (NumTaps * resampleRatio);

        if (lowpassRatio < 0.8)
            lowpassRatio = 0.8;
        if (lowpassRatio < resampleRatio)
            lowpassRatio = resampleRatio;

        return Math.Min(1.0, lowpassRatio * resampleRatio);
    }

    private static double BlackmanHarris(int index, int count)
    {
        const double a0 = 0.35875;
        const double a1 = 0.48829;
        const double a2 = 0.14128;
        const double a3 = 0.01168;
        double phase = 2 * Math.PI * index / (count - 1);
        return a0 - a1 * Math.Cos(phase) + a2 * Math.Cos(2 * phase) - a3 * Math.Cos(3 * phase);
    }

    private static double Sinc(double x)
    {
        if (Math.Abs(x) < 1e-12)
            return 1.0;

        double angle = Math.PI * x;
        return Math.Sin(angle) / angle;
    }

    private static int GreatestCommonDivisor(int a, int b)
    {
        while (b != 0)
        {
            int t = b;
            b = a % b;
            a = t;
        }

        return Math.Abs(a);
    }

    private static int Clamp(int value, int min, int max)
        => value < min ? min : value > max ? max : value;

    private static int Quantize(double value)
        => (int)Math.Round(value * 1_000_000);

    private readonly record struct KernelKey(int OldRate, int NewRate, int FilterCount, int Cutoff);
}
