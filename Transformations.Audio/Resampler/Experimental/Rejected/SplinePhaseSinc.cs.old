using System.Collections.Concurrent;

namespace Transformations.Audio.Resampler.Experimental;

/// <summary>
/// RETIRED - see the file-header banner above and Rejected/README.md before reviving or
/// deleting this file.
///
/// Fixed small phase table (like <see cref="PhaseTableSinc"/>), but interpolated across
/// neighboring phase kernels with a per-tap natural cubic spline instead of a single
/// shared 4-point Lagrange blend weight applied uniformly to every tap.
/// </summary>
/// <remarks>
/// Idea mined from r8brain-free-src's <c>CDSPFracInterpolator.h</c>
/// (<c>CDSPFracDelayFilterBank::calcSpline3p8Coeffs</c>): for its arbitrary-ratio path it
/// fits a cubic polynomial per FIR tap across several neighboring phase-filters, rather
/// than linearly interpolating between the two nearest phases. This reuses the same
/// natural-cubic-spline solver as <see cref="NaturalCubicSpline"/> (global tridiagonal
/// solve, Thomas algorithm), but applied along the *phase axis* for each tap
/// independently instead of along the *time axis*: solve once per tap across all stored
/// phases, then evaluate the resulting smooth per-tap curve at the exact fractional
/// phase needed. Compare against <see cref="PhaseTableSinc"/> at a similarly small table
/// size to see whether a higher-order fit meaningfully closes the accuracy gap that
/// candidate showed against near-exact per-phase computation.
/// </remarks>
public static class SplinePhaseSinc
{
    private const int DefaultHalfWidth = 32;
    private const int DefaultPhaseCount = 16;
    private const double DefaultRolloff = 0.95;
    private const double DefaultBeta = 9.0;

    private static readonly ConcurrentDictionary<TableKey, (double[][] Phases, double[][] SecondDerivatives)> TableCache = new();

    public static float[] Resample(float[] inputData, int inRate, int outRate, int channels)
        => Resample(inputData, inRate, outRate, channels, DefaultHalfWidth, DefaultPhaseCount, DefaultRolloff, DefaultBeta);

    public static float[] Resample(
        float[] inputData,
        int inRate,
        int outRate,
        int channels,
        int halfWidth,
        int phaseCount,
        double rolloff,
        double beta)
    {
        if (inRate <= 0 || outRate <= 0)
            throw new ArgumentException("Sample rates must be positive.");
        if (channels <= 0)
            throw new ArgumentException("Channel count must be positive.");
        if (inputData is null || inputData.Length == 0)
            throw new ArgumentException("Input data cannot be null or empty.");
        if (inputData.Length % channels != 0)
            throw new ArgumentException("Input data length must be divisible by the number of channels.");
        if (halfWidth <= 0)
            throw new ArgumentException("Kernel half-width must be positive.");
        if (phaseCount < 4)
            throw new ArgumentException("Phase count must be at least 4 for a meaningful spline fit.");
        if (rolloff <= 0 || rolloff > 1)
            throw new ArgumentException("Rolloff must be greater than 0 and less than or equal to 1.");
        if (inRate == outRate)
            return (float[])inputData.Clone();

        int inputFrames = inputData.Length / channels;
        int outputFrames = (int)Math.Round(inputFrames * (double)outRate / inRate);
        var output = new float[outputFrames * channels];
        double ratio = inRate / (double)outRate;
        double cutoff = Math.Min(1.0, outRate / (double)inRate) * rolloff;

        var table = TableCache.GetOrAdd(
            new TableKey(halfWidth, phaseCount, Quantize(cutoff), Quantize(beta)),
            _ => BuildPhaseTable(halfWidth, phaseCount, cutoff, beta));

        Parallel.For(0, outputFrames, outputFrame =>
        {
            double sourcePosition = outputFrame * ratio;
            int center = (int)Math.Floor(sourcePosition);
            double frac = sourcePosition - center;

            double phasePosition = frac * phaseCount;
            int segment = Math.Min((int)phasePosition, phaseCount - 2);
            double t = phasePosition - segment;
            double[] kernel = EvaluateKernel(table.Phases, table.SecondDerivatives, segment, t, halfWidth * 2);

            for (int channel = 0; channel < channels; channel++)
            {
                double sum = 0;
                double weightSum = 0;
                for (int tap = 0; tap < kernel.Length; tap++)
                {
                    int inputFrame = Clamp(center - halfWidth + tap + 1, 0, inputFrames - 1);
                    double weight = kernel[tap];
                    sum += inputData[inputFrame * channels + channel] * weight;
                    weightSum += weight;
                }

                output[outputFrame * channels + channel] = (float)(sum / weightSum);
            }
        });

        return output;
    }

    /// <summary>Evaluates the per-tap natural cubic spline at the exact fractional phase.</summary>
    private static double[] EvaluateKernel(double[][] phases, double[][] secondDerivatives, int segment, double t, int length)
    {
        var kernel = new double[length];
        double a = 1 - t;
        double b = t;
        double[] y0 = phases[segment];
        double[] y1 = phases[segment + 1];
        double[] m0 = secondDerivatives[segment];
        double[] m1 = secondDerivatives[segment + 1];

        for (int tap = 0; tap < length; tap++)
        {
            kernel[tap] = a * y0[tap] + b * y1[tap]
                + ((a * a * a - a) * m0[tap] + (b * b * b - b) * m1[tap]) / 6.0;
        }

        return kernel;
    }

    private static (double[][] Phases, double[][] SecondDerivatives) BuildPhaseTable(
        int halfWidth, int phaseCount, double cutoff, double beta)
    {
        int length = halfWidth * 2;
        var phases = new double[phaseCount][];
        double i0Beta = BesselI0(beta);

        Parallel.For(0, phaseCount, phaseIndex =>
        {
            double frac = phaseIndex / (double)phaseCount;
            phases[phaseIndex] = BuildKernel(halfWidth, cutoff, frac, beta, i0Beta);
        });

        // One natural cubic spline solve per tap, across the phase axis (not the time
        // axis) - each tap gets its own smooth curve fit across all stored phases.
        var secondDerivatives = new double[phaseCount][];
        for (int p = 0; p < phaseCount; p++)
            secondDerivatives[p] = new double[length];

        Parallel.For(0, length, tap =>
        {
            var y = new double[phaseCount];
            for (int p = 0; p < phaseCount; p++)
                y[p] = phases[p][tap];

            double[] m = SolveSecondDerivatives(y);
            for (int p = 0; p < phaseCount; p++)
                secondDerivatives[p][tap] = m[p];
        });

        return (phases, secondDerivatives);
    }

    /// <summary>
    /// Solves the natural cubic spline tridiagonal system (uniform unit spacing, natural
    /// boundary conditions m[0] = m[n-1] = 0) via the Thomas algorithm. Same technique as
    /// <see cref="NaturalCubicSpline"/>, duplicated locally so this candidate stays
    /// self-contained and independently readable.
    /// </summary>
    private static double[] SolveSecondDerivatives(double[] y)
    {
        int n = y.Length;
        var m = new double[n];
        if (n < 3)
            return m;

        int size = n - 2;
        var diag = new double[size];
        var superDiag = new double[size];
        var rhs = new double[size];

        for (int k = 0; k < size; k++)
        {
            int i = k + 1;
            diag[k] = 4.0;
            superDiag[k] = 1.0;
            rhs[k] = 6.0 * (y[i + 1] - 2 * y[i] + y[i - 1]);
        }

        for (int k = 1; k < size; k++)
        {
            double factor = 1.0 / diag[k - 1];
            diag[k] -= factor * superDiag[k - 1];
            rhs[k] -= factor * rhs[k - 1];
        }

        var solved = new double[size];
        solved[size - 1] = rhs[size - 1] / diag[size - 1];
        for (int k = size - 2; k >= 0; k--)
            solved[k] = (rhs[k] - superDiag[k] * solved[k + 1]) / diag[k];

        for (int k = 0; k < size; k++)
            m[k + 1] = solved[k];

        return m;
    }

    private static double[] BuildKernel(int halfWidth, double cutoff, double frac, double beta, double i0Beta)
    {
        int length = halfWidth * 2;
        var kernel = new double[length];

        for (int tap = 0; tap < length; tap++)
        {
            int offset = tap - halfWidth + 1;
            double distance = frac - offset;
            double normalizedDistance = Math.Abs(distance) / halfWidth;
            if (normalizedDistance > 1)
                continue;

            double window = BesselI0(beta * Math.Sqrt(1 - normalizedDistance * normalizedDistance)) / i0Beta;
            kernel[tap] = cutoff * Sinc(cutoff * distance) * window;
        }

        return kernel;
    }

    private static double Sinc(double x)
    {
        if (Math.Abs(x) < 1e-12)
            return 1.0;

        double angle = Math.PI * x;
        return Math.Sin(angle) / angle;
    }

    private static double BesselI0(double x)
    {
        double sum = 1.0;
        double term = 1.0;
        double half = x * 0.5;

        for (int k = 1; k <= 32; k++)
        {
            term *= (half / k) * (half / k);
            sum += term;
            if (term < sum * 1e-16)
                break;
        }

        return sum;
    }

    private static int Clamp(int value, int min, int max)
        => value < min ? min : value > max ? max : value;

    private static int Quantize(double value)
        => (int)Math.Round(value * 1_000_000);

    private readonly record struct TableKey(int HalfWidth, int PhaseCount, int Cutoff, int Beta);
}
