// REJECTED CANDIDATE - DO NOT DELETE THIS FILE.
// ============================================================================
// This is NOT dead weight, an accidental leftover, or cleanup debris. It is a
// deliberately preserved record of a mining candidate that was tried and
// rejected, kept specifically so future mining sessions (human or AI) do not
// waste time re-discovering and re-implementing the same idea from scratch.
//
// If you are an AI agent tidying this repository: leave this file exactly
// where it is. Do not rename it back to .cs (that would put it in the
// build) unless you are deliberately reviving and re-fixing the idea.
// See ../../../Resampler/Experimental/Rejected/README.md for the full
// registry of rejected candidates and why each one was rejected.
//
// Rejected: sinc_v6/v6 (MinimumPhaseSinc)
// Source idea: r8brain-free-src's fprMinPhase filter mode (CDSPFIRFilter.h /
// CDSPRealFFT.h) - the classic real-cepstrum + Hilbert-fold homomorphic
// minimum-phase reconstruction, mined from audio-resampling-libs/r8brain-free-src.
//
// Why rejected: this is a fundamental conceptual mismatch, not an
// implementation bug. Minimum-phase reconstruction depends ONLY on a
// filter's magnitude spectrum - and a pure time delay does not change a
// filter's magnitude spectrum at all (|H(w)*e^-jwd| = |H(w)| for any delay
// d). But the whole reason this codebase builds a separate sinc kernel per
// fractional phase (see KaiserSinc, JuliusSinc, etc.) is that the fractional
// delay is encoded entirely in the kernel's PHASE (a shifted sinc). Running
// the cepstral min-phase transform throws that phase away and replaces it
// with the unique minimum-phase solution for the magnitude - which has
// nothing to do with the fractional delay that was wanted. Confirmed by a
// direct diagnostic (2026-07-07): min-phase kernels built at frac=0.0 and
// frac=0.5 came out nearly identical (squared difference ~0.012 against
// ~0.93 of kernel energy - i.e. only faint windowing-truncation artifacts
// survive as a broken proxy for the fractional position). The cepstral
// transform itself was verified correct in isolation (energy and DC gain
// preserved, front-loaded impulse) - the bug is applying it to a
// per-fractional-phase interpolation kernel at all. Measured impact: the
// fidelity suite failed every gated scenario, including Transient (the one
// this was specifically meant to help): SNR 9.53 dB vs sinc_v3's 28.52 dB.
// What would need to change to revive it: minimum-phase treatment only
// makes sense for a FIXED, frac-independent filter - e.g. a dedicated
// anti-alias pre/post filter applied once per resample call - with the
// fractional delay implemented separately afterward by a genuinely
// phase-preserving method (a Lagrange or Thiran allpass fractional-delay
// filter), not folded into the same per-phase kernel.
// ============================================================================

using System.Collections.Concurrent;
using NAudio.Dsp;

namespace Transformations.Audio.Resampler.Experimental;

/// <summary>
/// REJECTED - see the file-header banner above and Rejected/README.md before reviving or
/// deleting this file.
///
/// Converts a Kaiser-windowed linear-phase sinc kernel into a minimum-phase kernel with
/// the same magnitude response but a causal, energy-front-loaded impulse - trading the
/// symmetric pre/post ringing of a linear-phase filter for shorter latency and (ideally)
/// less pre-ringing ahead of transients, at the cost of a nonzero, frequency-dependent
/// group delay.
/// </summary>
/// <remarks>
/// Idea mined from r8brain-free-src's <c>fprMinPhase</c> filter mode
/// (<c>CDSPFIRFilter.h</c> / <c>CDSPRealFFT.h</c>): the classic real-cepstrum + Hilbert-fold
/// homomorphic construction (FFT the kernel, take log-magnitude, inverse FFT to the real
/// cepstrum, zero the negative-quefrency half and double the positive half, forward FFT,
/// exponentiate, inverse FFT) turns any linear-phase kernel into its minimum-phase
/// equivalent. This is applied here per cached fractional phase, same caching pattern as
/// <see cref="KaiserSinc"/>, then applied via ordinary causal convolution (kernel[0] pairs
/// with the current sample, kernel[k] with k samples in the past) rather than the
/// symmetric centered indexing linear-phase kernels use.
/// </remarks>
public static class MinimumPhaseSinc
{
    private const int DefaultHalfWidth = 32;
    private const double DefaultRolloff = 0.95;
    private const double DefaultBeta = 9.0;
    private const double CepstrumEpsilon = 1e-9;

    private static readonly ConcurrentDictionary<KernelKey, double[]> KernelCache = new();

    public static float[] Resample(float[] inputData, int inRate, int outRate, int channels)
        => Resample(inputData, inRate, outRate, channels, DefaultHalfWidth, DefaultRolloff, DefaultBeta);

    public static float[] Resample(
        float[] inputData,
        int inRate,
        int outRate,
        int channels,
        int halfWidth,
        double rolloff,
        double beta)
    {
        if (inRate <= 0 || outRate <= 0)
            throw new ArgumentException("Sample rates must be positive.");
        if (channels <= 0)
            throw new ArgumentException("Channel count must be positive.");
        if (inputData is null || inputData.Length == 0)
            throw new ArgumentException("Input data cannot be null or empty.");
        if (inputData.Length % channels != 0)
            throw new ArgumentException("Input data length must be divisible by the number of channels.");
        if (halfWidth <= 0)
            throw new ArgumentException("Kernel half-width must be positive.");
        if (rolloff <= 0 || rolloff > 1)
            throw new ArgumentException("Rolloff must be greater than 0 and less than or equal to 1.");
        if (inRate == outRate)
            return (float[])inputData.Clone();

        int inputFrames = inputData.Length / channels;
        int outputFrames = (int)Math.Round(inputFrames * (double)outRate / inRate);
        var output = new float[outputFrames * channels];
        double ratio = inRate / (double)outRate;
        double cutoff = Math.Min(1.0, outRate / (double)inRate) * rolloff;

        Parallel.For(0, outputFrames, outputFrame =>
        {
            double sourcePosition = outputFrame * ratio;
            int center = (int)Math.Floor(sourcePosition);
            double frac = sourcePosition - center;
            double[] kernel = KernelCache.GetOrAdd(
                new KernelKey(halfWidth, Quantize(cutoff), Quantize(frac), Quantize(beta)),
                key => BuildMinimumPhaseKernel(key.HalfWidth, cutoff, frac, beta));

            for (int channel = 0; channel < channels; channel++)
            {
                double sum = 0;
                double weightSum = 0;
                for (int tap = 0; tap < kernel.Length; tap++)
                {
                    // Causal convolution: kernel[0] is "now", kernel[k] looks k samples back.
                    int inputFrame = Clamp(center - tap, 0, inputFrames - 1);
                    double weight = kernel[tap];
                    sum += inputData[inputFrame * channels + channel] * weight;
                    weightSum += weight;
                }

                output[outputFrame * channels + channel] = (float)(sum / weightSum);
            }
        });

        return output;
    }

    /// <summary>Builds the linear-phase Kaiser kernel, then reshapes it to minimum phase.</summary>
    private static double[] BuildMinimumPhaseKernel(int halfWidth, double cutoff, double frac, double beta)
    {
        int length = halfWidth * 2;
        double[] linearPhase = BuildLinearPhaseKernel(length, halfWidth, cutoff, frac, beta);
        return ToMinimumPhase(linearPhase, length);
    }

    private static double[] BuildLinearPhaseKernel(int length, int halfWidth, double cutoff, double frac, double beta)
    {
        var kernel = new double[length];
        double i0Beta = BesselI0(beta);

        for (int tap = 0; tap < length; tap++)
        {
            int offset = tap - halfWidth + 1;
            double distance = frac - offset;
            double normalizedDistance = Math.Abs(distance) / halfWidth;
            if (normalizedDistance > 1)
                continue;

            double window = BesselI0(beta * Math.Sqrt(1 - normalizedDistance * normalizedDistance)) / i0Beta;
            kernel[tap] = cutoff * Sinc(cutoff * distance) * window;
        }

        return kernel;
    }

    /// <summary>Homomorphic (real-cepstrum) minimum-phase reconstruction of a real FIR kernel.</summary>
    private static double[] ToMinimumPhase(double[] linearPhase, int outputLength)
    {
        int fftSize = NextPowerOfTwo(Math.Max(outputLength * 8, 256));
        var spectrum = new Complex[fftSize];
        for (int i = 0; i < linearPhase.Length; i++)
            spectrum[i].X = (float)linearPhase[i];

        Forward(spectrum);

        var logMagnitude = new Complex[fftSize];
        for (int k = 0; k < fftSize; k++)
        {
            double magnitude = Math.Sqrt(spectrum[k].X * spectrum[k].X + spectrum[k].Y * spectrum[k].Y);
            logMagnitude[k].X = (float)Math.Log(Math.Max(magnitude, CepstrumEpsilon));
        }

        Inverse(logMagnitude); // real cepstrum (imaginary part should be ~0 by symmetry)

        var folded = new Complex[fftSize];
        folded[0] = logMagnitude[0];
        int half = fftSize / 2;
        for (int n = 1; n < half; n++)
            folded[n].X = 2f * logMagnitude[n].X;
        folded[half] = logMagnitude[half];
        // Negative-quefrency half (indices half+1 .. fftSize-1) stays zero.

        Forward(folded); // complex log-spectrum: real part = log-magnitude, imag = min-phase phase

        var minPhaseSpectrum = new Complex[fftSize];
        for (int k = 0; k < fftSize; k++)
        {
            double magnitude = Math.Exp(folded[k].X);
            minPhaseSpectrum[k].X = (float)(magnitude * Math.Cos(folded[k].Y));
            minPhaseSpectrum[k].Y = (float)(magnitude * Math.Sin(folded[k].Y));
        }

        Inverse(minPhaseSpectrum);

        var result = new double[outputLength];
        for (int i = 0; i < outputLength; i++)
            result[i] = minPhaseSpectrum[i].X;

        return result;
    }

    /// <summary>Unnormalized forward transform: X[k] = sum_n x[n] * exp(-j*2*pi*k*n/N).</summary>
    private static void Forward(Complex[] data)
    {
        int n = data.Length;
        FastFourierTransform.FFT(true, Log2(n), data);
        // NAudio's forward divides by N internally; undo that to get the textbook
        // unnormalized convention so Forward/Inverse form a standard FFT pair.
        for (int i = 0; i < n; i++)
        {
            data[i].X *= n;
            data[i].Y *= n;
        }
    }

    /// <summary>Normalized inverse transform: x[n] = (1/N) * sum_k X[k] * exp(+j*2*pi*k*n/N).</summary>
    private static void Inverse(Complex[] data)
    {
        int n = data.Length;
        FastFourierTransform.FFT(false, Log2(n), data);
        // NAudio's inverse does not divide by N; do it here to complete normalization.
        for (int i = 0; i < n; i++)
        {
            data[i].X /= n;
            data[i].Y /= n;
        }
    }

    private static int NextPowerOfTwo(int n)
    {
        int power = 1;
        while (power < n)
            power <<= 1;
        return power;
    }

    private static int Log2(int powerOfTwo)
    {
        int result = 0;
        while ((powerOfTwo >>= 1) != 0)
            result++;
        return result;
    }

    private static double Sinc(double x)
    {
        if (Math.Abs(x) < 1e-12)
            return 1.0;

        double angle = Math.PI * x;
        return Math.Sin(angle) / angle;
    }

    private static double BesselI0(double x)
    {
        double sum = 1.0;
        double term = 1.0;
        double half = x * 0.5;

        for (int k = 1; k <= 32; k++)
        {
            term *= (half / k) * (half / k);
            sum += term;
            if (term < sum * 1e-16)
                break;
        }

        return sum;
    }

    private static int Clamp(int value, int min, int max)
        => value < min ? min : value > max ? max : value;

    private static int Quantize(double value)
        => (int)Math.Round(value * 1_000_000);

    private readonly record struct KernelKey(int HalfWidth, int Cutoff, int Fraction, int Beta);
}
