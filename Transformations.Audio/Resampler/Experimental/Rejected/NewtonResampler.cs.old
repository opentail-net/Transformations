namespace Transformations.Audio.Resampler.Experimental;

/// <summary>
/// 4th-order Newton divided-difference polynomial resampler combined with a 4th-order
/// Butterworth lowpass filter.
/// </summary>
public static class NewtonResampler
{
    private const double DefaultRolloff = 0.90;

    /// <summary>
    /// Resamples the given interleaved audio data using a Newton polynomial structure with default settings.
    /// </summary>
    public static float[] Resample(float[] inputData, int inRate, int outRate, int channels)
        => Resample(inputData, inRate, outRate, channels, DefaultRolloff);

    /// <summary>
    /// Resamples the given interleaved audio data using a Newton polynomial structure with custom settings.
    /// </summary>
    public static float[] Resample(
        float[] inputData,
        int inRate,
        int outRate,
        int channels,
        double rolloff)
    {
        if (inRate <= 0 || outRate <= 0)
            throw new ArgumentException("Sample rates must be positive.");
        if (channels <= 0)
            throw new ArgumentException("Channel count must be positive.");
        if (inputData is null || inputData.Length == 0)
            throw new ArgumentException("Input data cannot be null or empty.");
        if (inputData.Length % channels != 0)
            throw new ArgumentException("Input data length must be divisible by the number of channels.");
        if (inRate == outRate)
            return (float[])inputData.Clone();

        int inputFrames = inputData.Length / channels;
        int outputFrames = (int)Math.Round(inputFrames * (double)outRate / inRate);
        var output = new float[outputFrames * channels];
        double ratio = inRate / (double)outRate;
        double cutoff = Math.Min(1.0, outRate / (double)inRate) * rolloff;

        float[] filteredData = inputData;
        if (cutoff < 0.99)
        {
            filteredData = ApplyButterworthLowPass(inputData, channels, cutoff);
        }

        Parallel.For(0, outputFrames, outputFrame =>
        {
            double sourcePosition = outputFrame * ratio;
            int center = (int)Math.Floor(sourcePosition);
            double d = sourcePosition - center; // d in [0, 1)

            // Interpolate using 5 samples centered around center:
            // Indices: center-2, center-1, center, center+1, center+2
            // Grid points: x0=-2, x1=-1, x2=0, x3=1, x4=2
            // Target: d

            for (int channel = 0; channel < channels; channel++)
            {
                int idx0 = Clamp(center - 2, 0, inputFrames - 1);
                int idx1 = Clamp(center - 1, 0, inputFrames - 1);
                int idx2 = Clamp(center, 0, inputFrames - 1);
                int idx3 = Clamp(center + 1, 0, inputFrames - 1);
                int idx4 = Clamp(center + 2, 0, inputFrames - 1);

                double f0 = filteredData[idx0 * channels + channel];
                double f1 = filteredData[idx1 * channels + channel];
                double f2 = filteredData[idx2 * channels + channel];
                double f3 = filteredData[idx3 * channels + channel];
                double f4 = filteredData[idx4 * channels + channel];

                // Divided differences (grid spacing = 1):
                // 1st order differences
                double d1_0 = f1 - f0;
                double d1_1 = f2 - f1;
                double d1_2 = f3 - f2;
                double d1_3 = f4 - f3;

                // 2nd order differences (denominators: x2-x0 = 2)
                double d2_0 = (d1_1 - d1_0) / 2.0;
                double d2_1 = (d1_2 - d1_1) / 2.0;
                double d2_2 = (d1_3 - d1_2) / 2.0;

                // 3rd order differences (denominators: x3-x0 = 3)
                double d3_0 = (d2_1 - d2_0) / 3.0;
                double d3_1 = (d2_2 - d2_1) / 3.0;

                // 4th order difference (denominator: x4-x0 = 4)
                double d4_0 = (d3_1 - d3_0) / 4.0;

                // Newton evaluation:
                // P(d) = f0 + (d + 2)*d1_0 + (d + 2)*(d + 1)*d2_0 + (d + 2)*(d + 1)*d*d3_0 + (d + 2)*(d + 1)*d*(d - 1)*d4_0
                double term1 = d + 2.0;
                double term2 = term1 * (d + 1.0);
                double term3 = term2 * d;
                double term4 = term3 * (d - 1.0);

                double result = f0 + term1 * d1_0 + term2 * d2_0 + term3 * d3_0 + term4 * d4_0;
                output[outputFrame * channels + channel] = (float)result;
            }
        });

        return output;
    }

    private static float[] ApplyButterworthLowPass(float[] data, int channels, double cutoff)
    {
        int frames = data.Length / channels;
        var output = new float[data.Length];

        double q1 = 0.54119610;
        double q2 = 1.30656296;

        var section1 = GetBiquadCoefficients(cutoff, q1);
        var section2 = GetBiquadCoefficients(cutoff, q2);

        for (int ch = 0; ch < channels; ch++)
        {
            double x1_1 = 0.0, x2_1 = 0.0, y1_1 = 0.0, y2_1 = 0.0;
            double x1_2 = 0.0, x2_2 = 0.0, y1_2 = 0.0, y2_2 = 0.0;

            for (int i = 0; i < frames; i++)
            {
                double x = data[i * channels + ch];

                double y_s1 = (section1.b0 * x + section1.b1 * x1_1 + section1.b2 * x2_1
                              - section1.a1 * y1_1 - section1.a2 * y2_1);
                x2_1 = x1_1;
                x1_1 = x;
                y2_1 = y1_1;
                y1_1 = y_s1;

                double y_s2 = (section2.b0 * y_s1 + section2.b1 * x1_2 + section2.b2 * x2_2
                              - section2.a1 * y1_2 - section2.a2 * y2_2);
                x2_2 = x1_2;
                x1_2 = y_s1;
                y2_2 = y1_2;
                y1_2 = y_s2;

                output[i * channels + ch] = (float)y_s2;
            }
        }

        return output;
    }

    private static BiquadCoeffs GetBiquadCoefficients(double cutoff, double Q)
    {
        double K = Math.Tan(Math.PI * cutoff / 2.0);
        double D = K * K + K / Q + 1.0;

        return new BiquadCoeffs
        {
            b0 = K * K / D,
            b1 = 2.0 * K * K / D,
            b2 = K * K / D,
            a1 = 2.0 * (K * K - 1.0) / D,
            a2 = (K * K - K / Q + 1.0) / D
        };
    }

    private static int Clamp(int value, int min, int max)
        => value < min ? min : value > max ? max : value;

    private struct BiquadCoeffs
    {
        public double b0;
        public double b1;
        public double b2;
        public double a1;
        public double a2;
    }
}
